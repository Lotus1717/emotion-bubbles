/* 念起 - 首页样式 */

/* 容器 */
.container {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

/* 背景星星 */
.stars {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  background-image: 
    radial-gradient(2px 2px at 20px 30px, #fff, rgba(0,0,0,0)),
    radial-gradient(2px 2px at 40px 70px, #fff, rgba(0,0,0,0)),
    radial-gradient(2px 2px at 50px 160px, #fff, rgba(0,0,0,0)),
    radial-gradient(2px 2px at 90px 40px, #fff, rgba(0,0,0,0)),
    radial-gradient(2px 2px at 130px 80px, #fff, rgba(0,0,0,0));
  background-repeat: repeat;
  background-size: 200px 200px;
  animation: twinkle 4s ease-in-out infinite;
}

@keyframes twinkle {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 1; }
}

/* 开始面板 */
.start-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx 40rpx;
}

.start-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 72rpx;
  font-weight: bold;
  letter-spacing: 0.3em;
  background: linear-gradient(135deg, #fff 0%, #ffd700 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 20rpx;
}

.start-settings {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
  width: 100%;
  max-width: 500rpx;
  margin-bottom: 60rpx;
}

.setting-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.setting-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

/* 主题选项 */
.theme-options {
  display: flex;
  gap: 32rpx;
  justify-content: center;
}

.theme-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  cursor: pointer;
  transition: all 0.3s ease;
  border: 4rpx solid transparent;
  opacity: 0.6;
}

.theme-btn.healing {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.theme-btn.forest {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.theme-btn.sunset {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.theme-btn.active {
  opacity: 1;
  border-color: rgba(255, 215, 0, 0.8);
  box-shadow: 0 0 40rpx rgba(255, 215, 0, 0.3);
}

/* 时间选项 */
.time-options {
  display: flex;
  gap: 16rpx;
  justify-content: center;
}

.time-btn {
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.7);
}

.time-btn.active {
  background: rgba(255, 215, 0, 0.2);
  border-color: rgba(255, 215, 0, 0.5);
  color: #ffd700;
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 60rpx;
  font-size: 32rpx;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.8);
  border-radius: 40rpx;
}

.btn-large {
  padding: 24rpx 120rpx;
  font-size: 36rpx;
  margin-bottom: 32rpx;
}

.btn-small {
  padding: 16rpx 32rpx;
  font-size: 24rpx;
  border-radius: 30rpx;
}

/* 辅助按钮 */
.start-actions {
  display: flex;
  gap: 48rpx;
}

.btn-text {
  background: none;
  border: none;
  color: rgba(255, 255, 255, 0.5);
  font-size: 26rpx;
  padding: 16rpx;
}

/* 提醒面板 */
.reminder-panel {
  background: rgba(255, 255, 255, 0.03);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 32rpx;
  width: 100%;
  max-width: 500rpx;
  margin-top: 32rpx;
}

.reminder-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.reminder-label {
  color: rgba(255, 255, 255, 0.7);
  font-size: 26rpx;
}

.reminder-time-text {
  color: #ffd700;
  font-size: 32rpx;
}

/* 游戏面板 */
.play-panel {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.hint-top {
  position: absolute;
  top: 40rpx;
  left: 0;
  width: 100%;
  text-align: center;
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
  z-index: 10;
}

.bubble-container {
  position: absolute;
  top: 100rpx;
  left: 0;
  width: 100%;
  height: calc(100% - 300rpx);
}

.bubble {
  position: absolute;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: float 6s ease-in-out infinite;
}

.bubble-text {
  font-size: 24rpx;
  color: #fff;
  text-align: center;
}

.play-footer {
  position: absolute;
  bottom: 40rpx;
  left: 0;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
}

.progress-bar {
  flex: 1;
  max-width: 400rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2);
  transition: width 0.3s ease;
}

.timer-display {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  min-width: 80rpx;
  text-align: center;
}

.btn-end-early {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 16rpx 32rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
}

/* 结果面板 */
.result-panel {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(10, 10, 26, 0.95);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
  overflow-y: auto;
}

.result-title {
  font-size: 40rpx;
  margin-bottom: 16rpx;
}

.emotion-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  max-width: 600rpx;
  margin-bottom: 40rpx;
}

.emotion-tag {
  padding: 12rpx 24rpx;
  background: rgba(255, 215, 0, 0.2);
  border: 2rpx solid rgba(255, 215, 0, 0.5);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #ffd700;
}

.ai-suggestion {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 20rpx;
  padding: 32rpx;
  max-width: 600rpx;
  margin-bottom: 40rpx;
}

.ai-suggestion-title {
  display: block;
  font-size: 28rpx;
  color: #ffd700;
  margin-bottom: 16rpx;
}

.ai-suggestion-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.6;
}

.result-buttons {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
  justify-content: center;
}

/* 统计面板 */
.stats-panel {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(10, 10, 26, 0.95);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  overflow-y: auto;
}

.stats-filter {
  display: flex;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.filter-btn {
  padding: 12rpx 32rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.filter-btn.active {
  background: rgba(255, 215, 0, 0.2);
  border-color: rgba(255, 215, 0, 0.5);
  color: #ffd700;
}

.stats-overview {
  display: flex;
  gap: 24rpx;
  margin-bottom: 40rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.stat-card {
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
  text-align: center;
  min-width: 160rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffd700;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 8rpx;
}

.stats-buttons {
  display: flex;
  gap: 24rpx;
}
