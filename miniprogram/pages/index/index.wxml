<!-- 念起 - 首页 -->
<view class="container">
  <!-- 背景 -->
  <view class="stars"></view>
  
  <!-- 开始面板 -->
  <view class="start-panel" wx:if="{{state === 'idle'}}">
    <view class="start-header">
      <text class="title">念起</text>
      <text class="subtitle">念起即觉，觉已不随</text>
    </view>
    
    <!-- 设置区 -->
    <view class="start-settings">
      <view class="setting-group">
        <text class="setting-label">主题</text>
        <view class="theme-options">
          <view class="theme-btn healing {{theme==='healing'?'active':''}}" bindtap="setTheme" data-theme="healing"></view>
          <view class="theme-btn forest {{theme==='forest'?'active':''}}" bindtap="setTheme" data-theme="forest"></view>
          <view class="theme-btn sunset {{theme==='sunset'?'active':''}}" bindtap="setTheme" data-theme="sunset"></view>
        </view>
      </view>
      
      <view class="setting-group">
        <text class="setting-label">时长</text>
        <view class="time-options">
          <button class="time-btn {{duration===60?'active':''}}" bindtap="setDuration" data-time="60">1分钟</button>
          <button class="time-btn {{duration===180?'active':''}}" bindtap="setDuration" data-time="180">3分钟</button>
        </view>
      </view>
    </view>
    
    <!-- 主按钮 -->
    <button class="btn-primary btn-large" bindtap="startGame">开始</button>
    
    <!-- 辅助按钮 -->
    <view class="start-actions">
      <text class="btn-text" bindtap="showStats">查看历史</text>
      <text class="btn-text" bindtap="toggleReminder">每日提醒</text>
    </view>
    
    <!-- 提醒面板 -->
    <view class="reminder-panel" wx:if="{{showReminder}}">
      <view class="reminder-row">
        <text class="reminder-label">提醒时间</text>
        <picker mode="time" value="{{reminderTime}}" bindchange="bindTimeChange">
          <text class="reminder-time-text">{{reminderTime}}</text>
        </picker>
      </view>
      <button class="btn-small" bindtap="testNotification">测试通知</button>
    </view>
  </view>
  
  <!-- 游戏面板 -->
  <view class="play-panel" wx:if="{{state === 'playing'}}">
    <text class="hint-top">轻触泡影，让念头自然流过</text>
    <view class="bubble-container">
      <view wx:for="{{bubbles}}" wx:key="id" 
            class="bubble {{item.emotion}}"
            style="left:{{item.x}}rpx;top:{{item.y}}rpx;width:{{item.size}}rpx;height:{{item.size}}rpx;"
            bindtap="popBubble" data-id="{{item.id}}">
        <text class="bubble-text">{{item.emotion}}</text>
      </view>
    </view>
    <view class="play-footer">
      <view class="progress-bar">
        <view class="progress-fill" style="width:{{progress}}%"></view>
      </view>
      <text class="timer-display">{{displayTime}}</text>
    </view>
    <button class="btn-end-early" bindtap="endEarly">结束</button>
  </view>
  
  <!-- 结果面板 -->
  <view class="result-panel" wx:if="{{state === 'result'}}">
    <text class="result-title">你戳破的情绪</text>
    <view class="emotion-tags">
      <text wx:for="{{poppedEmotions}}" wx:key="index" class="emotion-tag">{{item}}</text>
    </view>
    <view class="ai-suggestion">
      <text class="ai-suggestion-title">✨ 小花的建议</text>
      <text class="ai-suggestion-text">{{suggestion}}</text>
    </view>
    <view class="result-buttons">
      <button class="btn-primary" bindtap="restartGame">再来一轮</button>
      <button class="btn-secondary" bindtap="shareResult">📤 分享</button>
    </view>
  </view>
  
  <!-- 统计面板 -->
  <view class="stats-panel" wx:if="{{state === 'stats'}}">
    <view class="stats-filter">
      <text class="filter-btn {{statsRange==='week'?'active':''}}" bindtap="setStatsRange" data-range="week">本周</text>
      <text class="filter-btn {{statsRange==='month'?'active':''}}" bindtap="setStatsRange" data-range="month">本月</text>
      <text class="filter-btn {{statsRange==='all'?'active':''}}" bindtap="setStatsRange" data-range="all">全部</text>
    </view>
    <view class="stats-overview">
      <view class="stat-card">
        <text class="stat-value">{{stats.totalPopped}}</text>
        <text class="stat-label">戳破总数</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{stats.totalDays}}</text>
        <text class="stat-label">练习天数</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{stats.avgPerDay}}</text>
        <text class="stat-label">日均戳破</text>
      </view>
    </view>
    <view class="stats-buttons">
      <button class="btn-secondary btn-small" bindtap="clearHistory">清空历史</button>
      <button class="btn-primary btn-small" bindtap="closeStats">返回</button>
    </view>
  </view>
</view>
