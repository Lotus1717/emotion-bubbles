<!-- 念起 - 首页 -->
<view class="container theme-{{theme}}">
  <!-- 背景星空 -->
  <view class="stars"></view>
  
  <!-- 开始面板 -->
  <view class="start-panel" wx:if="{{state === 'idle'}}">
    <view class="start-header">
      <text class="title">念起</text>
      <text class="subtitle">念起即觉，觉已不随</text>
    </view>
    
    <!-- 设置区 -->
    <view class="start-settings">
      <view class="setting-group">
        <text class="setting-label">主题</text>
        <view class="theme-options">
          <view class="theme-btn healing {{theme==='healing'?'active':''}}" bindtap="setTheme" data-theme="healing"></view>
          <view class="theme-btn forest {{theme==='forest'?'active':''}}" bindtap="setTheme" data-theme="forest"></view>
          <view class="theme-btn sunset {{theme==='sunset'?'active':''}}" bindtap="setTheme" data-theme="sunset"></view>
        </view>
      </view>
      
      <view class="setting-group">
        <text class="setting-label">时长</text>
        <view class="time-options">
          <view class="time-btn {{duration===60?'active':''}}" bindtap="setDuration" data-time="60">
            <text>1分钟</text>
          </view>
          <view class="time-btn {{duration===180?'active':''}}" bindtap="setDuration" data-time="180">
            <text>3分钟</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 主按钮 -->
    <view class="btn btn-primary btn-large" bindtap="startGame" hover-class="btn-hover">
      <text>开始</text>
    </view>
    
    <!-- 辅助按钮 -->
    <view class="start-actions">
      <view class="btn-text" bindtap="showStats" hover-class="btn-text-hover">
        <text>查看历史</text>
      </view>
      <view class="btn-text" bindtap="toggleReminder" hover-class="btn-text-hover">
        <text>每日提醒</text>
      </view>
    </view>
  </view>
  
  <!-- 提醒模态框 -->
  <view class="reminder-modal" wx:if="{{showReminder}}" catchtouchmove="preventTouchMove">
    <view class="reminder-modal-content">
      <view class="reminder-close-btn" bindtap="toggleReminder">
        <text>✕</text>
      </view>
      <text class="reminder-modal-title">每日提醒</text>
      <text class="reminder-modal-desc">设置一个固定时间提醒自己觉察情绪</text>
      
      <view class="reminder-settings">
        <view class="reminder-row">
          <text class="reminder-label">开启提醒</text>
          <view class="switch {{reminderEnabled?'active':''}}" bindtap="toggleReminderSwitch">
            <view class="switch-track"></view>
            <view class="switch-thumb"></view>
          </view>
        </view>
        
        <view class="reminder-time-wrapper" wx:if="{{reminderEnabled}}">
          <text class="reminder-label">提醒时间</text>
          <picker mode="time" value="{{reminderTime}}" bindchange="bindTimeChange">
            <view class="reminder-time-picker">
              <text class="reminder-time-text">{{reminderTime}}</text>
            </view>
          </picker>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 倒计时面板 -->
  <view class="countdown-panel" wx:if="{{state === 'countdown'}}">
    <text class="countdown">{{countdownNum}}</text>
  </view>
  
  <!-- 游戏面板 -->
  <view class="play-panel" wx:if="{{state === 'playing'}}">
    <text class="hint-top">轻触泡影，让念头自然流过</text>
    <view class="bubble-container">
      <view wx:for="{{bubbles}}" wx:key="id" 
            class="bubble bubble-{{item.category}} {{item.popping?'popping':''}}"
            style="left:{{item.x}}rpx;top:{{item.y}}rpx;width:{{item.size}}rpx;height:{{item.size}}rpx;animation-duration:{{item.floatDuration}}s;animation-delay:{{item.floatDelay}}s;"
            bindtap="popBubble" data-id="{{item.id}}">
        <view class="bubble-shine"></view>
        <text class="bubble-text">{{item.emotion}}</text>
      </view>
    </view>
    <view class="play-footer">
      <view class="progress-bar">
        <view class="progress-fill" style="width:{{progress}}%"></view>
      </view>
      <text class="timer-display">{{displayTime}}</text>
    </view>
    <view class="btn-end-early" bindtap="endEarly" hover-class="btn-hover">
      <text>结束</text>
    </view>
  </view>
  
  <!-- 结果面板 -->
  <view class="result-panel" wx:if="{{state === 'result'}}">
    <text class="result-title">你戳破的情绪</text>
    <text class="result-subtitle">这些都是你当下最真实的感受</text>
    <view class="emotion-tags">
      <view wx:for="{{poppedEmotions}}" wx:key="index" class="emotion-tag">
        <text>{{item}}</text>
      </view>
      <view wx:if="{{poppedEmotions.length===0}}" class="emotion-tag emotion-tag-empty">
        <text>这次你选择了暂停，也很好</text>
      </view>
    </view>
    <view class="ai-suggestion">
      <text class="ai-suggestion-title">✨ 小念的锦囊</text>
      <text class="ai-suggestion-text">{{suggestion}}</text>
    </view>
    <view class="result-buttons">
      <view class="btn btn-primary" bindtap="restartGame" hover-class="btn-hover">
        <text>再来一轮</text>
      </view>
      <view class="btn btn-secondary" bindtap="shareResult" hover-class="btn-hover">
        <text>📤 分享</text>
      </view>
      <view class="btn btn-secondary" bindtap="closeResult" hover-class="btn-hover">
        <text>关闭</text>
      </view>
    </view>
  </view>
  
  <!-- 统计面板 -->
  <view class="stats-panel" wx:if="{{state === 'stats'}}">
    <!-- 头部 -->
    <view class="stats-header">
      <text class="stats-title">情绪记录</text>
      <view class="stats-close-btn" bindtap="closeStats">
        <text>✕</text>
      </view>
    </view>
    
    <!-- 时间筛选 -->
    <view class="stats-filter">
      <view class="filter-btn {{statsRange==='week'?'active':''}}" bindtap="setStatsRange" data-range="week">
        <text>本周</text>
      </view>
      <view class="filter-btn {{statsRange==='month'?'active':''}}" bindtap="setStatsRange" data-range="month">
        <text>本月</text>
      </view>
      <view class="filter-btn {{statsRange==='all'?'active':''}}" bindtap="setStatsRange" data-range="all">
        <text>全部</text>
      </view>
    </view>
    
    <!-- 概览统计 -->
    <view class="stats-overview">
      <view class="stat-card">
        <text class="stat-value">{{stats.totalPopped}}</text>
        <text class="stat-label">戳破总数</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{stats.totalDays}}</text>
        <text class="stat-label">练习天数</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{stats.avgPerDay}}</text>
        <text class="stat-label">日均戳破</text>
      </view>
    </view>
    
    <!-- 趋势图表 -->
    <view class="stats-trend" wx:if="{{trendData.length > 0}}">
      <text class="stats-section-title">练习趋势</text>
      <view class="trend-chart">
        <view class="trend-bar" wx:for="{{trendData}}" wx:key="date">
          <view class="trend-bar-fill" style="height:{{item.height}}%"></view>
          <text class="trend-label">{{item.label}}</text>
        </view>
      </view>
    </view>
    
    <!-- Top 情绪 -->
    <view class="stats-top" wx:if="{{topEmotions.length > 0}}">
      <text class="stats-section-title">高频情绪</text>
      <view class="top-list">
        <view class="top-item" wx:for="{{topEmotions}}" wx:key="emotion">
          <text class="top-emotion">{{item.emotion}}</text>
          <text class="top-count">{{item.count}}</text>
        </view>
      </view>
    </view>
    
    <!-- 空状态 -->
    <view class="empty-tip" wx:if="{{stats.totalPopped === 0}}">
      <text>还没有练习记录，开始第一次情绪觉察吧 ✨</text>
    </view>
    
    <!-- 底部按钮 -->
    <view class="stats-footer" wx:if="{{stats.totalPopped > 0}}">
      <view class="btn-text-danger" bindtap="clearHistory" hover-class="btn-text-hover">
        <text>清空历史</text>
      </view>
    </view>
  </view>
</view>
