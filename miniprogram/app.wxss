/**
 * 念起 - 小程序全局样式（深度适配版）
 */

/* ===========================================
   1. 页面基础
   =========================================== */
page {
  background: #080818;
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  min-height: 100vh;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  font-size: 28rpx;
  line-height: 1.5;
}

/* ===========================================
   2. 全局重置
   =========================================== */
view, text, image, navigator {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

/* 彻底清除 button 默认样式 */
button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: none;
  outline: none;
  line-height: inherit;
  font-size: inherit;
  color: inherit;
  border-radius: 0;
  -webkit-appearance: none;
}

button::after {
  display: none;
  border: none;
}

button[plain] {
  background: transparent;
  border: none;
}

/* ===========================================
   3. 滚动条隐藏
   =========================================== */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  background: transparent;
}

/* ===========================================
   4. 安全区适配
   =========================================== */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-area-top {
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}
